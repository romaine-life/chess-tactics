.DS_Store

# BGM and all other media are hosted in backend-owned storage (see tofu/ and the
# runtime asset contract), never committed to the repo or baked into the image.
*.mp3

# OpenTofu local working artifacts. Provider versions + the lockfile are injected
# by the shared pipeline (see tofu/provider.tf), so neither is committed here.
.terraform/
.terraform.lock.hcl

# Local Claude Code tooling: worktrees, launch config, and a scratch dir used
# for headless screenshot capture (Playwright + Chromium). Never committed —
# except checked-in skills under .claude/skills/, which ship with the repo.
.claude/*
!.claude/skills/
.pwshot/
frontend/.codex-vite-*.log
frontend/.chrome-campaign-proof/
tmp-shots/
.unit-art-output/

# Advance Wars ROMs — copyrighted, never commit (see tools/aw-import)
roms/
