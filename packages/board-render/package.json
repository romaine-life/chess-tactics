{
  "name": "@chess-tactics/board-render",
  "version": "0.1.19",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "npm run build && node --test tests/*.test.mjs",
    "typecheck": "node ../../frontend/node_modules/typescript/bin/tsc -p tsconfig.json --noEmit"
  }
}
