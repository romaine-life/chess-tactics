{
  "_doc": "Single source of truth for atom-built 9-slice frames. Read by the Node bake (scripts/nine-slice-kit.mjs), the in-app editor (NineSliceEditor), and the catalog edit-link (AssetLibraryStudio). Add a frame here and it becomes bakeable, editable, and catalog-linked with no other code change. atoms = names in public/assets/ui/kit/atoms; variants[].out = composed PNG in public/assets/ui/kit; swap = palette name; consume = the CSS var its content drives; carve = flood navy bleed outside the rail.",
  "palettes": {
    "active": {
      "faefbb": "d6f4ff", "c79b55": "4fbdf0", "a7793d": "2f93dd", "5b4124": "14507f",
      "414e61": "2896c3", "2f3a48": "1c608c",
      "121c23": "1c3a5a", "0f181f": "152f4c", "0d151c": "122a46", "101921": "183452"
    }
  },
  "assets": {
    "mode-button": {
      "label": "Mode button (tabs / header)",
      "atoms": { "corner": "corner", "edge": "edge", "fill": "fill" },
      "frame": { "w": 72, "h": 72 },
      "consume": { "selector": ".settings-tab", "cssVar": "--settings-tab-content" },
      "variants": [
        { "out": "mode-button.png" },
        { "out": "mode-button-active.png", "swap": "active", "inspect": "corner-cyan" }
      ]
    },
    "panel": {
      "label": "Settings panel / frame",
      "atoms": { "corner": "corner", "edge": "edge", "fill": "fill" },
      "frame": { "w": 72, "h": 72 },
      "variants": [{ "out": "panel.png" }]
    },
    "row": {
      "label": "Settings row",
      "atoms": { "corner": "row-corner", "edge": "row-edge", "fill": "row-fill" },
      "frame": { "w": 160, "h": 112 },
      "carve": true,
      "flipSides": true,
      "variants": [{ "out": "row.png" }]
    }
  }
}
