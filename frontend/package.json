{
  "name": "chess-tactics-frontend",
  "version": "0.1.19",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/start-vite-dev.mjs",
    "build": "vite build",
    "build:trainer": "vite build --config vite.trainer.config.js",
    "build:board-render": "npm --prefix ../packages/board-render run build",
    "preview": "vite preview --host 0.0.0.0",
    "shot": "node scripts/shot.mjs",
    "e2e:lobby": "node scripts/lobby-e2e.mjs",
    "vendor:ambience": "node scripts/vendor-ambience.mjs",
    "assets:build:macro-tiles": "python scripts/build-macro-tiles.py",
    "units:native": "python ../scripts/generate-unit-art.py",
    "optimize:assets": "node scripts/optimize-main-menu-assets.mjs",
    "visual:screenshot": "node scripts/screenshot-local-page.mjs",
    "visual:health": "node scripts/check-local-server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "node --check src/bgm.js && node scripts/check-no-committed-media.mjs --allow-frozen-cutover 11a6290a9aed299d8124581b4d566a716f53f4578c03bb6685bcdcfcf180fda9 --allow-cutover-importer && node scripts/check-bgm-shuffle.mjs && node scripts/check-imagegen-gate.mjs && node scripts/check-light-art-chrome.mjs && node scripts/check-titlebar-actions.mjs && node scripts/check-empty-panel-frame-overlay.mjs && node scripts/check-no-dev-data-seam.mjs && vitest run && tsc --noEmit",
    "check:media-final": "node scripts/check-no-committed-media.mjs"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "pngjs": "^7.0.0",
    "puppeteer-core": "^25.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@chess-tactics/board-render": "file:../packages/board-render",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  }
}
