{
  "name": "chess-tactics-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "shot": "node scripts/shot.mjs",
    "optimize:assets": "node scripts/optimize-main-menu-assets.mjs",
    "tiles:extract-concept": "node scripts/extract-concept-materials.mjs",
    "tiles:base-refresh": "node scripts/generate-base-refresh-tiles.mjs",
    "tiles:transition-fill": "node scripts/generate-transition-fill-tiles.mjs",
    "tiles:clean": "node scripts/generate-clean-canonical-tiles.mjs",
    "tiles:animated": "node scripts/generate-animated-tile-prototypes.mjs",
    "tiles:lock-water-animation": "node scripts/lock-water-animation-to-canonical.mjs",
    "tiles:uv-lock-water-animation": "node scripts/uv-lock-water-animation-to-canonical.mjs",
    "tiles:template": "node scripts/generate-tile-template.mjs",
    "tiles:true-iso": "node scripts/normalize-true-iso-tiles.mjs",
    "tiles:validate-true-iso": "node scripts/validate-true-iso-tiles.mjs",
    "units:sprites": "node scripts/generate-unit-sprites.mjs",
    "units:normalize-concepts": "node scripts/normalize-unit-direction-concepts.mjs",
    "units:review-directions": "node scripts/generate-unit-direction-review.mjs",
    "units:rook-pixel-first-review": "node scripts/generate-rook-pixel-first-review.mjs",
    "campaign:assets": "node scripts/generate-campaign-editor-ui-assets.mjs",
    "pixellab:download": "node scripts/download-pixellab-tiles.mjs",
    "visual:screenshot": "node scripts/screenshot-local-page.mjs",
    "visual:health": "node scripts/check-local-server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "node --check src/bgm.js && node scripts/check-no-chrome-bitmaps.mjs && node scripts/check-bgm-shuffle.mjs && node scripts/check-sprites.mjs && vitest run && tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  }
}
