{
  "name": "chess-tactics-frontend",
  "version": "0.1.19",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-backend-deps.mjs && npm --prefix ../packages/board-render run build",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:trainer": "vite build --config vite.trainer.config.js",
    "build:board-render": "npm --prefix ../packages/board-render run build",
    "preview": "vite preview --host 0.0.0.0",
    "shot": "node scripts/shot.mjs",
    "e2e:lobby": "node scripts/lobby-e2e.mjs",
    "vendor:ambience": "node scripts/vendor-ambience.mjs",
    "assets:diagnose:terrain": "node scripts/diagnose-terrain-assets.mjs",
    "optimize:assets": "node scripts/optimize-main-menu-assets.mjs",
    "units:sprites": "node scripts/generate-unit-sprites.mjs",
    "units:normalize-concepts": "node scripts/normalize-unit-direction-concepts.mjs",
    "units:review-directions": "node scripts/generate-unit-direction-review.mjs",
    "units:rook-pixel-first-review": "node scripts/generate-rook-pixel-first-review.mjs",
    "campaign:assets": "node scripts/generate-campaign-editor-ui-assets.mjs",
    "visual:screenshot": "node scripts/screenshot-local-page.mjs",
    "visual:health": "node scripts/check-local-server.mjs",
    "assets:repair:terrain-top-bleed": "python scripts/repair-surface-top-bleed.py",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "node --check src/bgm.js && node scripts/check-no-chrome-bitmaps.mjs && node scripts/check-bgm-shuffle.mjs && node scripts/check-sprites.mjs && node scripts/check-imagegen-gate.mjs && node scripts/check-light-art-chrome.mjs && node scripts/check-titlebar-rule-kit.mjs && node scripts/check-titlebar-actions.mjs && node scripts/check-no-dev-data-seam.mjs && vitest run && tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "pngjs": "^7.0.0",
    "puppeteer-core": "^25.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@chess-tactics/board-render": "file:../packages/board-render",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  }
}
